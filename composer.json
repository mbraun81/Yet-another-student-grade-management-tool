{
	"name" : "schulkompetenztool/schulkompetenztool",
	"type" : "project",
	"license" : "MIT",
	"minimum-stability" : "stable",
	"prefer-stable" : true,
	"config" : {
		"allow-plugins" : {
			"php-http/discovery" : true,
			"symfony/flex" : true,
			"symfony/runtime" : true
		},
		"bump-after-update" : true,
		"sort-packages" : true,
		"bin-dir" : "bin/",
		"vendor-dir" : "vendor/"
	},
	"autoload" : {
		"psr-4" : {
			"App\\" : "src/"
		}
	},
	"autoload-dev" : {
		"psr-4" : {
			"App\\Tests\\" : "tests/"
		}
	},
	"replace" : {
		"symfony/polyfill-ctype" : "*",
		"symfony/polyfill-iconv" : "*",
		"symfony/polyfill-php72" : "*",
		"symfony/polyfill-php73" : "*",
		"symfony/polyfill-php74" : "*",
		"symfony/polyfill-php80" : "*",
		"symfony/polyfill-php81" : "*",
		"symfony/polyfill-php82" : "*",
		"symfony/polyfill-php83" : "*",
		"symfony/polyfill-php84" : "*"
	},
	"scripts" : {
		"auto-scripts" : {
			"cache:clear": "symfony-cmd",
			"assets:install %PUBLIC_DIR%": "symfony-cmd",
			"importmap:install": "symfony-cmd"
		},
		"post-install-cmd" : "@auto-scripts",
		"post-update-cmd" : "@auto-scripts"
	},
	"extra" : {
		"symfony" : {
			"allow-contrib" : false,
			"require" : "8.0.*"
		}
	},
	"require-dev" : {
		"phpunit/phpunit": "^11.5.55",
		"symfony/maker-bundle": ">=1.66",
		"symfony/phpunit-bridge": "^8.0.7",
		"symfony/web-profiler-bundle": ">=8.0.7",
		"zenstruck/browser": ">=1.10",
		"zenstruck/console-test": ">=1.8",
		"zenstruck/foundry": ">=2.9.2",
		"zenstruck/mailer-test": ">=1.5"
	},
	"require" : {
		"php": ">=8.4",
		"ext-ctype": "*",
		"ext-iconv": "*",
		"doctrine/dbal": ">=4.4.2",
		"doctrine/doctrine-bundle": ">=3.2.2",
		"doctrine/doctrine-migrations-bundle": ">=4",
		"doctrine/orm": ">=3.6.2",
		"easycorp/easyadmin-bundle": ">=5.0.2",
		"paragonie/sodium_compat": "^2.5",
		"phpdocumentor/reflection-docblock": ">=6.0.2",
		"phpstan/phpdoc-parser": ">=2.3.2",
		"scheb/2fa-bundle": "^8.4",
		"scheb/2fa-totp": "^8.4",
		"symfony/asset": ">=8.0.6",
		"symfony/asset-mapper": ">=8.0.6",
		"symfony/console": ">=8.0.7",
		"symfony/doctrine-messenger": ">=8.0.6",
		"symfony/dotenv": ">=8.0.7",
		"symfony/expression-language": ">=8.0.4",
		"symfony/flex": ">=2.10",
		"symfony/form": ">=8.0.7",
		"symfony/framework-bundle": ">=8.0.7",
		"symfony/http-client": ">=8.0.7",
		"symfony/http-kernel": ">=8.0.7",
		"symfony/intl": ">=8.0.6",
		"symfony/ldap": "8.0.*",
		"symfony/mailer": ">=8.0.6",
		"symfony/mime": ">=8.0.7",
		"symfony/monolog-bundle": ">=4.0.1",
		"symfony/notifier": ">=8.0.6",
		"symfony/process": ">=8.0.5",
		"symfony/property-access": ">=8.0.4",
		"symfony/property-info": ">=8.0.7",
		"symfony/routing": ">=8.0.6",
		"symfony/runtime": ">=8.0.1",
		"symfony/security-bundle": ">=8.0.6",
		"symfony/serializer": ">=8.0.7",
		"symfony/stimulus-bundle": ">=2.32",
		"symfony/string": ">=8.0.6",
		"symfony/translation": ">=8.0.6",
		"symfony/twig-bundle": ">=8.0.4",
		"symfony/ux-turbo": ">=2.32",
		"symfony/validator": ">=8.0.7",
		"symfony/web-link": ">=8.0.4",
		"symfony/yaml": ">=8.0.6",
		"twig/extra-bundle": ">=3.23",
		"twig/twig": ">=3.23"
	}
}
