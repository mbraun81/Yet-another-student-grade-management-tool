{% extends 'base.html.twig' %}

{% block title %}Anmelden – Schulkompetenzen{% endblock %}

{% block body %}
<div style="max-width:400px;margin:80px auto;font-family:sans-serif;">
    <h1 style="text-align:center;margin-bottom:1.5rem;">Schulkompetenzen</h1>

    {% if error %}
        <div style="background:#fee;border:1px solid #c00;color:#c00;padding:.75rem 1rem;border-radius:4px;margin-bottom:1rem;">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    {% for message in app.flashes('error') %}
        <div style="background:#fee;border:1px solid #c00;color:#c00;padding:.75rem 1rem;border-radius:4px;margin-bottom:1rem;">
            {{ message }}
        </div>
    {% endfor %}

    <form method="post" action="{{ path('app_login_check') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div style="margin-bottom:1rem;">
            <label for="username" style="display:block;margin-bottom:.25rem;font-weight:bold;">Benutzername</label>
            <input
                type="text"
                id="username"
                name="username"
                value="{{ last_username }}"
                autofocus
                autocomplete="username"
                required
                style="width:100%;padding:.5rem .75rem;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;font-size:1rem;"
            >
        </div>

        <div style="margin-bottom:1.5rem;">
            <label for="password" style="display:block;margin-bottom:.25rem;font-weight:bold;">Passwort</label>
            <input
                type="password"
                id="password"
                name="password"
                autocomplete="current-password"
                required
                style="width:100%;padding:.5rem .75rem;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;font-size:1rem;"
            >
        </div>

        <button
            type="submit"
            style="width:100%;padding:.6rem;background:#2563eb;color:#fff;border:none;border-radius:4px;font-size:1rem;cursor:pointer;"
        >
            Anmelden
        </button>
    </form>
</div>
{% endblock %}
