{% extends 'base.html.twig' %}

{% block title %}Anmelden{% endblock %}

{% block body %}
<div class="ch-card ch-card--narrow">
    <h1 style="text-align:center;margin-top:0;margin-bottom:1.5rem;">Anmelden</h1>

    {% if error %}
        <div class="ch-alert--error">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    {% for message in app.flashes('error') %}
        <div class="ch-alert--error">{{ message }}</div>
    {% endfor %}

    <form method="post" action="{{ path('app_login_check') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="ch-form__group">
            <label for="username" class="ch-form__label">Benutzername</label>
            <input
                type="text"
                id="username"
                name="username"
                value="{{ last_username }}"
                autofocus
                autocomplete="username"
                required
                class="ch-form__input"
            >
        </div>

        <div class="ch-form__group" style="margin-bottom:1.5rem;">
            <label for="password" class="ch-form__label">Passwort</label>
            <input
                type="password"
                id="password"
                name="password"
                autocomplete="current-password"
                required
                class="ch-form__input"
            >
        </div>

        <button type="submit" class="ch-btn">Anmelden</button>
    </form>
</div>
{% endblock %}
