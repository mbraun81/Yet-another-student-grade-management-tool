{% extends 'base.html.twig' %}

{% block title %}Zwei-Faktor-Authentifizierung einrichten{% endblock %}

{% block body %}
<div style="max-width:480px;margin:60px auto;font-family:sans-serif;">
    <h1 style="text-align:center;margin-bottom:.5rem;">2FA einrichten</h1>
    <p style="text-align:center;color:#555;margin-bottom:2rem;">
        Scannen Sie den QR-Code mit Ihrer Authenticator-App (z.&nbsp;B. Google Authenticator oder Aegis),
        und geben Sie anschließend den angezeigten 6-stelligen Code ein.
    </p>

    {% for message in app.flashes('error') %}
        <div style="background:#fee;border:1px solid #c00;color:#c00;padding:.75rem 1rem;border-radius:4px;margin-bottom:1rem;">
            {{ message }}
        </div>
    {% endfor %}

    <div style="text-align:center;margin-bottom:1.5rem;">
        <canvas id="qr-canvas"></canvas>
    </div>

    <details style="margin-bottom:1.5rem;">
        <summary style="cursor:pointer;color:#2563eb;">Secret manuell eingeben</summary>
        <p style="margin-top:.5rem;font-family:monospace;word-break:break-all;background:#f4f4f4;padding:.5rem;border-radius:4px;">
            {{ totp_secret }}
        </p>
    </details>

    <form method="post" action="{{ path('app_2fa_setup_confirm') }}">
        <div style="margin-bottom:1rem;">
            <label for="totp_code" style="display:block;margin-bottom:.25rem;font-weight:bold;">Bestätigungscode</label>
            <input
                type="text"
                id="totp_code"
                name="totp_code"
                inputmode="numeric"
                autocomplete="one-time-code"
                maxlength="6"
                required
                autofocus
                placeholder="123456"
                style="width:100%;padding:.5rem .75rem;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;font-size:1.5rem;letter-spacing:.3em;text-align:center;"
            >
        </div>

        <button
            type="submit"
            style="width:100%;padding:.6rem;background:#16a34a;color:#fff;border:none;border-radius:4px;font-size:1rem;cursor:pointer;"
        >
            Code bestätigen
        </button>
    </form>
</div>

<script type="module">
import QRCode from 'qrcode';

const qrContent = {{ qr_content|json_encode|raw }};
QRCode.toCanvas(document.getElementById('qr-canvas'), qrContent, { width: 220, margin: 2 });
</script>
{% endblock %}
