{% extends 'base.html.twig' %}

{% block title %}2FA einrichten{% endblock %}

{% block body %}
<div class="ch-card ch-card--narrow" style="max-width:480px;">
    <h1 style="text-align:center;margin-top:0;margin-bottom:.5rem;">2FA einrichten</h1>
    <p style="text-align:center;color:var(--ch-muted);margin-bottom:2rem;">
        Scannen Sie den QR-Code mit Ihrer Authenticator-App (z.&nbsp;B. Google Authenticator oder Aegis),
        und geben Sie anschließend den angezeigten 6-stelligen Code ein.
    </p>

    {% for message in app.flashes('error') %}
        <div class="ch-alert--error">{{ message }}</div>
    {% endfor %}

    <div class="ch-totp-qr">
        <canvas id="qr-canvas"></canvas>
    </div>

    <details class="ch-totp-details">
        <summary>Secret manuell eingeben</summary>
        <p class="ch-totp-secret">{{ totp_secret }}</p>
    </details>

    <form method="post" action="{{ path('app_2fa_setup_confirm') }}">
        <div class="ch-form__group">
            <label for="totp_code" class="ch-form__label">Bestätigungscode</label>
            <input
                type="text"
                id="totp_code"
                name="totp_code"
                inputmode="numeric"
                autocomplete="one-time-code"
                maxlength="6"
                required
                autofocus
                placeholder="123456"
                class="ch-form__input ch-form__input--otp"
            >
        </div>

        <button type="submit" class="ch-btn ch-btn--confirm">Code bestätigen</button>
    </form>
</div>

<script type="module">
import QRCode from 'qrcode';

const qrContent = {{ qr_content|json_encode|raw }};
QRCode.toCanvas(document.getElementById('qr-canvas'), qrContent, { width: 220, margin: 2 });
</script>
{% endblock %}
