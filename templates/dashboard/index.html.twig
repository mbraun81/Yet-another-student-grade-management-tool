{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block header_nav %}
<nav class="ch-header__nav">
    <span style="font-size:.9rem;opacity:.8;">{{ app.user.userIdentifier }}</span>
    <a href="{{ path('app_logout') }}">Abmelden</a>
</nav>
{% endblock %}

{% block sidebar %}
<aside class="ch-sidebar">
    <div class="ch-sidebar__section">Verwaltung</div>
    <ul class="ch-sidebar__nav">
        <li>
            <a href="{{ path('app_dashboard') }}" class="active">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                Übersicht
            </a>
        </li>
        <li>
            <a href="#">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Schüler
            </a>
        </li>
        <li>
            <a href="#">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Klassen
            </a>
        </li>
        <li>
            <a href="#">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                Fächer
            </a>
        </li>
        <li>
            <a href="#">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                Kompetenzen
            </a>
        </li>
    </ul>
    <div class="ch-sidebar__footer">
        <a href="{{ path('app_logout') }}">Abmelden</a>
    </div>
</aside>
{% endblock %}

{% block body %}
<h1 style="margin-top:0;">Willkommen zum Kompetenztool!</h1>
<p style="color:var(--ch-muted);margin-top:-.5rem;">Schuljahr 2025/26 &middot; Campus Hebebrandstraße</p>

<div class="ch-dashboard-grid">
    <div class="ch-stat-card">
        <span class="ch-stat-card__label">Schüler</span>
        <span class="ch-stat-card__value">–</span>
        <span class="ch-stat-card__desc">noch keine Daten</span>
    </div>
    <div class="ch-stat-card">
        <span class="ch-stat-card__label">Klassen</span>
        <span class="ch-stat-card__value">–</span>
        <span class="ch-stat-card__desc">noch keine Daten</span>
    </div>
    <div class="ch-stat-card">
        <span class="ch-stat-card__label">Fächer</span>
        <span class="ch-stat-card__value">–</span>
        <span class="ch-stat-card__desc">noch keine Daten</span>
    </div>
    <div class="ch-stat-card">
        <span class="ch-stat-card__label">Kompetenzen</span>
        <span class="ch-stat-card__value">–</span>
        <span class="ch-stat-card__desc">noch keine Daten</span>
    </div>
</div>
{% endblock %}
