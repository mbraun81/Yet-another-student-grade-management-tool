<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Schulkompetenzen{% endblock %} – Campus Hebebrandstraße</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏫</text></svg>">
    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    {% endblock %}

    {% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js" integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y" crossorigin="anonymous"></script>
    {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>

<header class="ch-header">
    <div class="ch-header__inner">
        <a href="{% if app.user %}{{ path('app_dashboard') }}{% else %}{{ path('app_login') }}{% endif %}" class="ch-header__brand">
            <img src="{{ asset('img/logo-grün.svg') }}" alt="Campus Hebebrandstraße Logo" class="ch-header__logo">
            <div class="ch-header__wordmark">
                <span class="ch-header__name">campus hebebrandstraße</span>
                <span class="ch-header__sub">Schulkompetenzen</span>
            </div>
        </a>
        {% block header_nav %}{% endblock %}
    </div>
</header>

<div class="ch-layout">
    {% block sidebar %}{% endblock %}
    <main class="ch-main">
        {% block body %}{% endblock %}
    </main>
</div>

<footer class="ch-footer">
    <div class="ch-footer__inner">
        <span>Campus Hebebrandstraße &middot; Kellinghusenstraße 11, 20249 Hamburg</span>
    </div>
</footer>

</body>
</html>
